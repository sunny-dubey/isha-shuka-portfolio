---
interface Props {
  title: string;
  description: string;
  date: Date;
  tags: string[];
  slug: string;
}

const { title, description, date, tags, slug } = Astro.props;

const formattedDate = new Date(date).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<article class="card-elevated p-6 group relative overflow-hidden">
  <div class="absolute top-0 left-0 w-full h-1 bg-gradient-cta"></div>
  <a href={`/blog/${slug}`} class="block">
    <div class="flex flex-wrap gap-2 mb-3">
      {tags.map((tag) => (
        <span class="tag-pill">
          {tag}
        </span>
      ))}
    </div>
    <h3 class="font-heading text-xl font-semibold text-charcoal group-hover:text-rose transition-colors mb-2">
      {title}
    </h3>
    <p class="text-charcoal/60 text-sm mb-4 line-clamp-2">
      {description}
    </p>
    <time class="text-xs text-charcoal/40" datetime={date.toISOString()}>
      {formattedDate}
    </time>
  </a>
</article>
