---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
---

<BaseLayout title="Contact — Isha Shukla" description="Get in touch with Isha Shukla for SEO consulting, content writing, or collaboration opportunities.">
  <Hero
    title="Get in Touch"
    subtitle="Have a project in mind? Want to collaborate? I'd love to hear from you."
  />

  <section class="py-20 bg-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
        <!-- Contact Info -->
        <div class="fade-in">
          <h2 class="font-heading text-2xl font-bold text-charcoal mb-6">
            Let's Connect
          </h2>
          <p class="text-charcoal/70 leading-relaxed mb-8">
            Whether you're looking for SEO strategy, content writing, or a full organic growth plan — I'm here to help.
            Drop me a message and I'll get back to you within 24 hours.
          </p>

          <div class="space-y-6">
            <!-- Email -->
            <div class="flex items-start gap-4">
              <div class="w-10 h-10 bg-gradient-cta rounded-lg flex items-center justify-center flex-shrink-0">
                <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
              </div>
              <div>
                <h3 class="font-medium text-charcoal">Email</h3>
                <a href="mailto:hello@ishashukla.in" class="text-rose hover:text-rose-dark transition-colors">
                  hello@ishashukla.in
                </a>
              </div>
            </div>

            <!-- LinkedIn -->
            <div class="flex items-start gap-4">
              <div class="w-10 h-10 bg-gradient-cta rounded-lg flex items-center justify-center flex-shrink-0">
                <svg class="w-5 h-5 text-white" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                </svg>
              </div>
              <div>
                <h3 class="font-medium text-charcoal">LinkedIn</h3>
                <a href="https://linkedin.com/in/ishashukla" target="_blank" rel="noopener noreferrer" class="text-rose hover:text-rose-dark transition-colors">
                  linkedin.com/in/ishashukla
                </a>
              </div>
            </div>

            <!-- Instagram -->
            <div class="flex items-start gap-4">
              <div class="w-10 h-10 bg-gradient-cta rounded-lg flex items-center justify-center flex-shrink-0">
                <svg class="w-5 h-5 text-white" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
                </svg>
              </div>
              <div>
                <h3 class="font-medium text-charcoal">Instagram</h3>
                <a href="https://instagram.com/ishashukla" target="_blank" rel="noopener noreferrer" class="text-rose hover:text-rose-dark transition-colors">
                  @ishashukla
                </a>
              </div>
            </div>

            <!-- Location -->
            <div class="flex items-start gap-4">
              <div class="w-10 h-10 bg-gradient-cta rounded-lg flex items-center justify-center flex-shrink-0">
                <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
                </svg>
              </div>
              <div>
                <h3 class="font-medium text-charcoal">Location</h3>
                <p class="text-charcoal/60">India — available for remote work worldwide</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Contact Form -->
        <div class="fade-in">
          <form
            action="https://formspree.io/f/placeholder"
            method="POST"
            class="bg-gradient-section rounded-xl p-8 space-y-6"
          >
            <div>
              <label for="name" class="block text-sm font-medium text-charcoal mb-2">Name</label>
              <input
                type="text"
                id="name"
                name="name"
                required
                class="w-full px-4 py-3 rounded-lg border border-cream-dark bg-white text-charcoal focus:outline-none focus:ring-2 focus:ring-rose/50 focus:border-rose transition-colors"
                placeholder="Your name"
              />
            </div>

            <div>
              <label for="email" class="block text-sm font-medium text-charcoal mb-2">Email</label>
              <input
                type="email"
                id="email"
                name="email"
                required
                class="w-full px-4 py-3 rounded-lg border border-cream-dark bg-white text-charcoal focus:outline-none focus:ring-2 focus:ring-rose/50 focus:border-rose transition-colors"
                placeholder="you@example.com"
              />
            </div>

            <div>
              <label for="message" class="block text-sm font-medium text-charcoal mb-2">Message</label>
              <textarea
                id="message"
                name="message"
                rows="5"
                required
                class="w-full px-4 py-3 rounded-lg border border-cream-dark bg-white text-charcoal focus:outline-none focus:ring-2 focus:ring-rose/50 focus:border-rose transition-colors resize-none"
                placeholder="Tell me about your project..."
              ></textarea>
            </div>

            <button
              type="submit"
              class="btn-primary w-full text-center"
            >
              Send Message
            </button>
          </form>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
