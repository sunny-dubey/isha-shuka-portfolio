---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';

const skills = [
  { name: 'Tech Content Writing', description: 'Turning complex technical ideas into clear, thoughtful, and purposeful content for IT and tech companies.' },
  { name: 'Blog & Article Writing', description: 'Long-form articles, blog posts, and LinkedIn content that is simple, relatable, and meaningful.' },
  { name: 'Photography', description: 'Capturing moments with honesty and depth — because life is rare and meant to be experienced fully.' },
  { name: 'Real Estate Content', description: 'Understanding not just projects, but the stories and emotions behind them — content that connects.' },
];

const experience = [
  {
    role: 'Tech Content Writer',
    company: 'IT Company',
    period: 'Present',
    description: 'Turning complex ideas into clear, thoughtful, and purposeful content. Writing blogs, website content, and technical articles.',
  },
  {
    role: 'Content Writer',
    company: 'Real Estate',
    period: 'Previous',
    description: 'Worked in the real estate space, understanding not just projects but the stories and emotions behind them.',
  },
];
---

<BaseLayout title="About — Isha Shukla" description="Learn more about Isha Shukla — a writer, storyteller, and photographer who believes in creating connections through words.">
  <Hero
    title="About Me"
    subtitle="Writer, storyteller, and photographer with a passion for creating meaningful connections."
  />

  <!-- Bio Section -->
  <section class="py-20 bg-white">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <div class="grid grid-cols-1 lg:grid-cols-5 gap-12 lg:gap-16 items-start">
        <div class="lg:col-span-2 fade-in">
          <div class="sticky top-28">
            <div class="aspect-[4/5] rounded-2xl overflow-hidden">
              <img
                src="/images/isha.jpg"
                alt="Isha Shukla"
                class="w-full h-full object-cover"
              />
            </div>
            <div class="mt-6 card-elevated p-5 text-center">
              <p class="font-accent text-xl italic text-charcoal/70 leading-relaxed">
                "I may not aim for perfection, but I always aim to be real."
              </p>
            </div>
          </div>
        </div>

        <div class="lg:col-span-3 fade-in">
          <h2 class="font-accent text-4xl md:text-5xl font-semibold text-charcoal mb-3">
            Hi, I'm Isha.
          </h2>
          <p class="inline-flex items-center gap-2 bg-gradient-to-r from-rose/15 to-lavender/15 text-rose-dark font-medium text-sm px-4 py-2 rounded-full mb-8">
            <svg class="w-4 h-4 text-rose" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5a2.5 2.5 0 010-5 2.5 2.5 0 010 5z" />
            </svg>
            Noida, India
          </p>
          <div class="space-y-5 text-charcoal/70 text-lg leading-relaxed">
            <p>
              Since childhood, I have always been drawn to writing. Whether it was shayari, poems, or simple thoughts,
              expressing myself through words has always felt natural to me. Over time, this passion grew into something
              more meaningful.
            </p>
            <p>
              I also have a deep love for photography. When I capture a moment, I feel like I truly live it. It reminds
              me that life is rare and meant to be experienced fully. Alongside this, I maintain a small personal space —
              a kind of digital garden — where I collect my thoughts, learnings, and observations. It's a space that
              reflects how I see the world, and that perspective naturally flows into my writing. I write the way I see
              things — with honesty, depth, and attention to detail.
            </p>
            <p>
              Currently, I work as a <strong class="text-charcoal font-medium">Tech Content Writer</strong> in an IT company, where I turn complex ideas into clear,
              thoughtful, and purposeful content. I have also worked in the <strong class="text-charcoal font-medium">real estate space</strong>, which has helped me
              understand not just projects, but the stories and emotions behind them.
            </p>
            <p>
              For me, writing is not just about delivering information. It is about creating a connection. Whether it
              is a blog, a LinkedIn post, or website content, I focus on making it simple, relatable, and meaningful.
            </p>
            <p>
              If you are looking for content that connects and communicates clearly, I would love to work with you.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Skills -->
  <section class="py-20 bg-gradient-section">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <div class="text-center mb-12 fade-in">
        <p class="text-rose font-medium tracking-widest uppercase text-sm mb-3">What I bring</p>
        <h2 class="font-heading text-3xl md:text-4xl font-bold text-charcoal">
          What I Do
        </h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 fade-in">
        {skills.map((skill) => (
          <div class="card-elevated p-6">
            <h3 class="font-heading text-xl font-semibold text-charcoal mb-3 flex items-center gap-2">
              <span class="w-2 h-2 bg-rose rounded-full"></span>
              {skill.name}
            </h3>
            <p class="text-charcoal/60 leading-relaxed">{skill.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Experience -->
  <section class="py-20 bg-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6">
      <div class="text-center mb-12 fade-in">
        <p class="text-rose font-medium tracking-widest uppercase text-sm mb-3">My journey</p>
        <h2 class="font-heading text-3xl md:text-4xl font-bold text-charcoal">
          Experience
        </h2>
      </div>
      <div class="space-y-8 fade-in">
        {experience.map((exp) => (
          <div class="border-l-2 border-rose pl-6 pb-2">
            <div class="flex flex-wrap items-baseline gap-2 mb-1">
              <h3 class="font-heading text-xl font-semibold text-charcoal">{exp.role}</h3>
              <span class="text-charcoal/40">·</span>
              <span class="text-rose font-medium">{exp.company}</span>
            </div>
            <p class="text-sm text-charcoal/40 mb-2">{exp.period}</p>
            <p class="text-charcoal/60 leading-relaxed">{exp.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 bg-gradient-cta text-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 text-center fade-in">
      <h2 class="font-heading text-3xl md:text-4xl font-bold mb-6">
        Interested in Working Together?
      </h2>
      <p class="text-white/80 text-lg mb-8">
        Whether you need blog content, website copy, or tech writing — let's chat.
      </p>
      <a
        href="/contact"
        class="inline-block bg-white text-rose px-8 py-3 rounded-full font-semibold hover:bg-cream transition-colors shadow-lg"
      >
        Get in Touch
      </a>
    </div>
  </section>
</BaseLayout>
