---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import PhotoGrid from '../components/PhotoGrid.astro';
import Lightbox from '../components/Lightbox.astro';

const photos = [
  { src: 'https://images.unsplash.com/photo-1506744038136-46273834b3fb?w=800&fit=crop', alt: 'Mountain landscape at sunset' },
  { src: 'https://images.unsplash.com/photo-1469474968028-56623f02e42e?w=800&fit=crop', alt: 'Sunlit valley with rolling hills' },
  { src: 'https://images.unsplash.com/photo-1470071459604-3b5ec3a7fe05?w=800&fit=crop', alt: 'Foggy forest morning' },
  { src: 'https://images.unsplash.com/photo-1441974231531-c6227db76b6e?w=800&fit=crop', alt: 'Green forest path with sunlight' },
  { src: 'https://images.unsplash.com/photo-1472214103451-9374bd1c798e?w=800&fit=crop', alt: 'Golden hour over open field' },
  { src: 'https://images.unsplash.com/photo-1501854140801-50d01698950b?w=800&fit=crop', alt: 'Aerial view of green landscape' },
  { src: 'https://images.unsplash.com/photo-1465146344425-f00d5f5c8f07?w=800&fit=crop', alt: 'Wildflowers in golden light' },
  { src: 'https://images.unsplash.com/photo-1433086966358-54859d0ed716?w=800&fit=crop', alt: 'Waterfall surrounded by greenery' },
  { src: 'https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=800&fit=crop', alt: 'Calm lake with mountain reflection' },
];
---

<BaseLayout title="Photography — Isha Shukla" description="A collection of photographs by Isha Shukla — landscapes, nature, and moments captured through her lens.">
  <Hero
    title="Photography"
    subtitle="Capturing the world one frame at a time — landscapes, light, and the quiet beauty in between."
  />

  <section class="py-16 bg-cream">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <PhotoGrid photos={photos} />
    </div>
  </section>

  <Lightbox photos={photos} />
</BaseLayout>
